{
  "id": "com.badbrush.okrecord",
  "name": "OK-Record",
  "manifestVersion": 6,
  "version": "1.0.2",
  "main": "main.js",
  "featureFlags": {
    "enableAlerts": true
  },
  "host": {
    "app": "PS",
    "minVersion": "24.2.0",
    "data": {
      "apiVersion": 2
    }
  },
  "entryPoints": [
    {
      "type": "panel",
      "id": "okRecordPanel",
      "label": {
        "default": "OK-Record"
      },
      "minimumSize": {
        "width": 250,
        "height": 200
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 450,
        "height": 750
      },
      "preferredFloatingSize": {
        "width": 450,
        "height": 750
      },
      "icons": [
        {
          "width": 24,
          "height": 24,
          "path": "icons/plugin@1x.png"
        },
        {
          "width": 48,
          "height": 48,
          "path": "icons/plugin@2x.png"
        }
      ]
    }
  ],
  "addon": {
    "name": "ok-record-addon.uxpaddon"
  },
  "requiredPermissions": {
    "enableAddon": true,
    "localFileSystem": "request",
    "network": {
      "domains": [
        "https://xbadbrushx.github.io"
      ]
    },
    "launchProcess": {
      "extensions": [
        "",
        ".html"
      ],
      "schemes": [
        "https"
      ]
    }
  },
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/plugin@1x.png"
    },
    {
      "width": 48,
      "height": 48,
      "path": "icons/plugin@2x.png"
    }
  ]
}
